<?php
$pluginname = "storcli-temp";

$tile = '';
$tile .= '<tbody title="_(Show StorCLI ROC temperature (c0))_">';
$tile .= '<tr><td><b>_(StorCLI ROC Temp (c0))_</b></td></tr>';
$tile .= '<tr><td>';
$tile .= '<span class="w26">_(ROC)_</span> <span class="w72"><span id="storcli_temp_value">...</span></span><br>';
$tile .= '<span class="w26">_(Status)_</span> <span class="w72"><span id="storcli_temp_status">...</span></span><br>';
$tile .= '<span class="w26">_(Updated)_</span> <span class="w72"><span id="storcli_temp_time">...</span></span>';

$tile .= '<script>
(function(){
  var endpoint = "/plugins/storcli-temp/include/temperature.php?c=0";

  function setText(id, txt) {
    var el = document.getElementById(id);
    if (el) el.textContent = txt;
  }

  function setColor(temp) {
    var el = document.getElementById("storcli_temp_value");
    if (!el) return;
    if (temp === null || temp === undefined) { el.style.color = ""; return; }
    if (temp >= 70) el.style.color = "#d00";
    else if (temp >= 55) el.style.color = "#d80";
    else el.style.color = "#090";
  }

  async function refresh() {
    try {
      var r = await fetch(endpoint, {cache: "no-store"});
      var j = await r.json();
      if (!j || !j.ok) {
        setText("storcli_temp_value", "N/A");
        setText("storcli_temp_status", (j && j.message) ? j.message : "error");
        setText("storcli_temp_time", "");
        setColor(null);
        return;
      }

      var temp = (j.roc_c === null || j.roc_c === undefined) ? null : Number(j.roc_c);
      if (temp === null || Number.isNaN(temp)) setText("storcli_temp_value", "N/A");
      else setText("storcli_temp_value", temp + " °C");
      setColor(temp);

      var status = "Support=" + (j.support_temp ? "Yes" : "No") + ", ROC Sensor=" + (j.sensor_roc || "Unknown");
      setText("storcli_temp_status", status);
      setText("storcli_temp_time", j.ts_local || "");
    } catch (e) {
      setText("storcli_temp_value", "N/A");
      setText("storcli_temp_status", "fetch failed");
      setText("storcli_temp_time", "");
      setColor(null);
    }
  }

  refresh();
  setInterval(refresh, 10000);
})();
</script>';

$tile .= '</td></tr>';
$tile .= '</tbody>';

$mytiles[$pluginname]['column1'] = $tile;
?>
